{
    "name": "Python ML Environment",
    "dockerComposeFile": [
        "../docker/docker-compose.yml",
        "docker-compose.generated.yml"
    ],
    "initializeCommand": "bash .devcontainer/init-gpu.sh",
    "service": "python-workspace",
    "workspaceFolder": "/home/kujira/workspace/python-workspace-template",
    "shutdownAction": "stopCompose",
    "remoteUser": "kujira",
    "updateRemoteUserUID": true,
    "postCreateCommand": "uv sync --frozen && scripts/environments/install-githooks.sh",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": true,
            "configureZshAsDefaultShell": true,
            "installOhMyZsh": true,
            "upgradePackages": false,
            "username": "kujira"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "charliermarsh.ruff",
                "codezombiech.gitignore",
                "DavidAnson.vscode-markdownlint",
                "donjayamanne.githistory",
                "donjayamanne.vscode-default-python-kernel",
                "eamodio.gitlens",
                "github.copilot-chat",
                "grapecity.gc-excelviewer",
                "Gruntfuggly.todo-tree",
                "ionutvmi.path-autocomplete",
                "ise-hve-essentials.hve-core-all",
                "mecatroner.rainbow-csv",
                "ms-python.mypy-type-checker",
                "ms-python.python",
                "ms-toolsai.jupyter",
                "njpwerner.autodocstring",
                "redhadt.vscode-yaml",
                "streetsidesoftware.code-spell-checker",
                "tamasfe.even-better-toml",
                "timonwong.shellcheck"
            ],
            "settings": {
                "autoDocstring.docstringFormat": "google",
                "editor.formatOnSave": true,
                "mypy-type-checker.importStrategy": "fromEnvironment",
                "python.testing.pytestEnabled": true,
                "python.defaultInterpreterPath": "/home/kujira/.venv/bin/python",
                "[python]": {
                    "editor.formatOnSave": true,
                    "editor.codeActionsOnSave": {
                        "source.fixAll.ruff": "explicit",
                        "source.organizeImports.ruff": "explicit"
                    },
                    "editor.defaultFormatter": "charliermarsh.ruff",
                    "files.trimTrailingWhitespace": true
                },
                "notebook.formatOnSave.enabled": true,
                "notebook.codeActionsOnSave": {
                    "notebook.source.fixAll.ruff": "explicit",
                    "notebook.source.organizeImports.ruff": "explicit"
                }
            }
        }
    }
}
